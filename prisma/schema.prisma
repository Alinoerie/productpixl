generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  image            String?
  credits          Int       @default(10)
  planTier         String    @default("free")
  stripeCustomerId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  brands         Brand[]
  brandProfile   BrandProfile?
  products       Product[]
  orders         Order[]
  savedPlaybooks SavedPlaybook[]
  playbookRuns   PlaybookRun[]
}

model GuidePackLead {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("ecommerce-guide")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DemoBookingLead {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  platform    String?
  skuRange    String?
  notes       String?  @db.Text
  preferredAt DateTime
  timezone    String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([preferredAt])
}

model BrandProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  companyName        String?
  companyDescription String?  @db.Text
  targetAudience     String?
  displayName        String?
  primaryColor       String   @default("#6366F1")
  secondaryColor     String   @default("#0891B2")
  tone               String   @default("premium, trustworthy, conversion-focused")
  logoUrl            String?
  guidelines         String?  @db.Text
  brandStory         String?  @db.Text
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Brand {
  id          String   @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  amazonUrl   String?
  userId      String
  isDefault   Boolean  @default(false)

  language       String  @default("en")
  tagline        String?
  tone           String  @default("premium, trustworthy, conversion-focused")
  targetAudience String?
  brandValues    String? @db.Text
  brandAesthetic String?
  primaryColor   String  @default("#6366F1")
  secondaryColor String  @default("#0891B2")
  companyName        String?
  companyDescription String? @db.Text
  guidelines         String? @db.Text
  brandStory         String? @db.Text
  onboardingComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       Product[]
  savedPlaybooks SavedPlaybook[]
  playbookRuns   PlaybookRun[]
}

model Product {
  id              String  @id @default(cuid())
  name            String
  inputImageUrl   String
  brandId         String?
  userId          String
  pipelineType    String  @default("LISTING")
  marketplace     String  @default("AMAZON_US")

  dimensions      String?
  weight          String?
  materials       String?
  colors          String?
  keyFeatures     String?
  targetBuyer     String?
  competitors     String?
  brandGuidelines String?
  amazonCategory  String?
  brandRegistered Boolean @default(false)
  vibe            String?
  useCase         String?
  differentiators String?  @db.Text
  referenceImageUrls Json?

  analysisJson  Json?
  researchJson  Json?
  status        String  @default("QUEUED")
  pipelineStatus Json?

  playbookSlug  String?
  templateSlug  String?
  playbookRunId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand         Brand?       @relation(fields: [brandId], references: [id])
  playbookRun   PlaybookRun? @relation(fields: [playbookRunId], references: [id])
  assets        Asset[]
  listingCopies ListingCopy[]
}

model SavedPlaybook {
  id           String   @id @default(cuid())
  userId       String
  brandId      String
  playbookSlug String
  name         String
  config       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([userId, brandId])
}

model PlaybookRun {
  id             String   @id @default(cuid())
  userId         String
  brandId        String
  playbookSlug   String
  name           String?
  status         String   @default("DRAFT")
  totalCredits   Int      @default(0)
  completedCount Int      @default(0)
  config         Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([userId, brandId])
}

model Asset {
  id           String   @id @default(cuid())
  productId    String
  moduleId     String
  pipelineType String   @default("LISTING")
  imageUrl     String?
  videoUrl     String?
  targetWidth  Int?
  targetHeight Int?
  status       String   @default("PENDING")
  qaScore      Int?
  retryCount   Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ListingCopy {
  id               String   @id @default(cuid())
  productId        String
  marketplace      String   @default("AMAZON_US")
  title            String?
  bullets          Json?
  description      String?  @db.Text
  backendKeywords  String?
  status           String   @default("PENDING")
  errorMessage     String?
  grade            String?
  gradeScore       Int?
  gradedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplace])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  stripeSessionId String?  @unique
  stripePaymentId String?
  package         String
  credits         Int
  amount          Int
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
